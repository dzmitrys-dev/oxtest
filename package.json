{
  "name": "code-guardian",
  "version": "0.0.0",
  "description": "Code Guardian — Supply Chain Scanner (npm workspaces monorepo root)",
  "private": true,
  "license": "UNLICENSED",
  "workspaces": [
    "apps/api"
  ],
  "overrides": {
    "graphql": "16.14.2"
  },
  "scripts": {
    "build": "npm run build --workspace apps/api",
    "start:api": "npm run start:api --workspace apps/api",
    "start:worker": "npm run start:worker --workspace apps/api",
    "dev:api": "npm run dev:api --workspace apps/api",
    "dev:worker": "npm run dev:worker --workspace apps/api",
    "typecheck": "npm run typecheck --workspace apps/api",
    "test": "npm run test --workspace apps/api",
    "lint": "npm run lint --workspace apps/api"
  }
}
